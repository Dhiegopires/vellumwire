{
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/tailwind-src.css -o ./assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/tailwind-src.css -o ./assets/css/tailwind.css --watch",
    "build:menu": "terser assets/js/menu.js -c -m -o assets/js/menu.min.js",
    "build:i18n-pages": "node scripts/build-i18n-pages.js"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "terser": "^5.48.0"
  }
}
